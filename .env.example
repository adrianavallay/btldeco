# ============================================================
# BTLDECO — Plantilla de variables de entorno
# ============================================================
# Copiar este archivo a .env y completar con valores reales.
# El archivo .env NUNCA debe commitearse.
# ============================================================

# Base de datos
DB_HOST=localhost
DB_NAME=tu_base_de_datos
DB_USER=tu_usuario_db
DB_PASS=tu_password_db

# Admin
ADMIN_USER=admin
# Generar con: php -r "echo password_hash('tu_password', PASSWORD_DEFAULT);"
ADMIN_PASS_HASH=$2y$12$replace_with_real_hash

# MercadoPago — obtener en https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...
# Webhook signing secret (Notificaciones > Configuración > Generar clave secreta)
MP_WEBHOOK_SECRET=

# Notificaciones
NOTIFY_EMAIL=tu@email.com

# ============================================================
# Correo Argentino — API Paq.ar v1
# ============================================================
# Ambiente: "test" (default) o "prod".
#   test -> https://apitest.correoargentino.com.ar
#   prod -> https://api.correoargentino.com.ar
CORREO_ARGENTINO_ENV=test

# API Key entregada por el área Comercial de Correo Argentino.
CORREO_ARGENTINO_API_KEY=

# ID del acuerdo comercial (string, aunque sea numérico).
CORREO_ARGENTINO_AGREEMENT=

# sellerId default. Si queda vacío, el middleware lo completa con el agreement.
CORREO_ARGENTINO_DEFAULT_SELLER_ID=

# extClient: exactamente 3 caracteres numéricos. Si vacío, el server agrega "000".
CORREO_ARGENTINO_EXT_CLIENT=

# Timeouts en segundos.
CORREO_ARGENTINO_TIMEOUT=30
CORREO_ARGENTINO_TIMEOUT_LABELS=60
