# ============================================================
# BTLDECO — Plantilla de variables de entorno
# ============================================================
# Copiar este archivo a .env y completar con valores reales.
# El archivo .env NUNCA debe commitearse.
# ============================================================

# Base de datos
DB_HOST=localhost
DB_NAME=tu_base_de_datos
DB_USER=tu_usuario_db
DB_PASS=tu_password_db

# Admin
ADMIN_USER=admin
# Generar con: php -r "echo password_hash('tu_password', PASSWORD_DEFAULT);"
ADMIN_PASS_HASH=$2y$10$replace_with_real_hash
# Dejar vacío en producción una vez que ADMIN_PASS_HASH esté en uso
ADMIN_PASS_PLAIN=

# MercadoPago — obtener en https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-...
MP_PUBLIC_KEY=APP_USR-...

# Notificaciones
NOTIFY_EMAIL=tu@email.com
